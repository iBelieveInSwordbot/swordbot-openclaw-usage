# Swordbot OpenClaw Usage - Configuration
# Copy to .env and adjust if needed.

# Server
PORT=4848
DATA_DIR=./data

# OpenClaw sessions root (all agents scanned under here)
OPENCLAW_ROOT=~/.openclaw

# Scanner poll interval (ms). Also uses fs.watch for near-realtime.
SCAN_INTERVAL_MS=30000

# When true, applies our local pricing table to models where OpenClaw
# didn't record cost.total (Gemini, GPT-5, minimax, etc). Set false to
# only trust OpenClaw's own cost.total.
USE_LOCAL_PRICING=true

# Slack webhook for optional daily digest / anomaly alerts.
SLACK_WEBHOOK_URL=
